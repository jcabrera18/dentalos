{
  "name": "dentalos-api",
  "version": "1.0.0",
  "description": "DentalOS — REST API (Fastify + Supabase)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --skipLibCheck --noEmitOnError false --noUnusedLocals false --noUnusedParameters false --noImplicitReturns false",
    "start": "node dist/server.js",
    "migrate": "node scripts/migrate.js",
    "migrate:reset": "node scripts/migrate.js --reset",
    "lint": "eslint src --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@supabase/supabase-js": "^2.43.0",
    "bullmq": "^5.7.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "ioredis": "^5.3.2",
    "jose": "^6.2.2",
    "jwks-rsa": "^4.0.1",
    "pg": "^8.12.0",
    "twilio": "^5.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "eslint": "^9.4.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}